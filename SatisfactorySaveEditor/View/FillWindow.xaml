<Window x:Class="SatisfactorySaveEditor.View.FillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SatisfactorySaveEditor.Util"
        mc:Ignorable="d"
        DataContext="{Binding FillViewModel, Source={StaticResource Locator}, Mode=OneTime}"
        WindowStartupLocation="CenterOwner"
        x:Name="FillInventoryWindow"
        Background="{DynamicResource Brush.Window}"
        Foreground="{DynamicResource Brush.FG1}"
        FontFamily="{StaticResource Font.UI}"
        TextOptions.TextFormattingMode="Display"
        Title="{loc:Tr Key=FillWindowTitle}" SizeToContent="Height" Width="440" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource Text.Header}" Text="{loc:Tr Key=FillWindowHeader}" />
            <TextBlock Style="{StaticResource Text.Caption}" Text="{loc:Tr Key=FillWindowSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <HeaderedContentControl Header="{loc:Tr Key=FillWindowItemType}">
                    <ComboBox ItemsSource="{Binding ItemTypes}"
                              SelectedIndex="0"
                              TextSearch.TextPath="Name"
                              SelectedItem="{Binding SelectedItem}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding Image}" Width="20" Height="20" Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="Fant" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </HeaderedContentControl>

                <HeaderedContentControl Header="{loc:Tr Key=FillWindowQuantityPerStack}">
                    <TextBox Text="{Binding SelectedItem.Quantity, UpdateSourceTrigger=PropertyChanged}" />
                </HeaderedContentControl>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Margin="0,0,8,0"
                    Padding="20,6"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding ElementName=FillInventoryWindow}" />
            <Button Content="{loc:Tr Key=ButtonFill}"
                    Padding="20,6"
                    Style="{StaticResource Button.Accent}"
                    IsDefault="True"
                    Command="{Binding OkCommand}"
                    IsEnabled="{Binding CanConfirm}"
                    CommandParameter="{Binding ElementName=FillInventoryWindow}" />
        </StackPanel>
    </Grid>
</Window>
