<UserControl x:Class="SatisfactorySaveEditor.View.Control.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converter="clr-namespace:SatisfactorySaveEditor.Converter"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converter:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="R" />
                <TextBox x:Name="RBox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Color.R, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="OnTextChanged" />
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="G" />
                <TextBox x:Name="GBox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Color.G, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="OnTextChanged" />
            </DockPanel>
        </Border>

        <Border Grid.Column="4" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="B" />
                <TextBox x:Name="BBox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Color.B, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="OnTextChanged" />
            </DockPanel>
        </Border>

        <Border Grid.Column="6" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="A" />
                <TextBox x:Name="ABox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Color.A, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="OnTextChanged" />
            </DockPanel>
        </Border>

        <Border x:Name="PreviewRectangle" Grid.Column="8" Width="28" Height="28"
                CornerRadius="{StaticResource Radius.Small}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                Background="{Binding Color, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ColorToBrushConverter}, Mode=OneWay}" />
    </Grid>
</UserControl>
