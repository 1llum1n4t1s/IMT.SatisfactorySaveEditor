<UserControl x:Class="SatisfactorySaveEditor.View.Control.PropertiesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:converter="clr-namespace:SatisfactorySaveEditor.Converter"
             xmlns:util="clr-namespace:SatisfactorySaveEditor.Util"
             xmlns:loc="clr-namespace:SatisfactorySaveEditor.Util"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converter:SerializablePropertyToTypeStringConverter x:Key="SerializablePropertyToTypeStringConverter" />
        <util:BindingProxy x:Key="Proxy" Data="{Binding .}" />
    </UserControl.Resources>

    <DockPanel>
        <!-- セクションヘッダー -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Style="{StaticResource Text.SubHeader}" Text="{loc:Tr Key=PropertiesTitle}" />
            <TextBlock Style="{StaticResource Text.Caption}"
                       Text="{loc:Tr Key=PropertiesSubtitle}" />
        </StackPanel>

        <!-- フッターの追加ボタン -->
        <Button DockPanel.Dock="Bottom"
                Margin="0,10,0,0"
                HorizontalAlignment="Left"
                Padding="14,6"
                Content="{loc:Tr Key=ButtonAddProperty}"
                Command="{Binding AddPropertyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding .}" />

        <!-- プロパティ表 -->
        <Border BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}"
                Background="{DynamicResource Brush.ContainerAlt}">
            <DataGrid ScrollViewer.CanContentScroll="False"
                      IsReadOnly="True"
                      SelectionUnit="Cell"
                      ItemsSource="{Binding Properties, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      RowHeight="{x:Static sys:Double.NaN}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeRows="False">
                <DataGrid.Resources>
                    <ResourceDictionary>
                        <ResourceDictionary.MergedDictionaries>
                            <ResourceDictionary Source="../PropertyTemplateDictionary.xaml" />
                        </ResourceDictionary.MergedDictionaries>

                        <!-- セルだけテーマ既定の上に ContextMenu と Tooltip を載せる -->
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="ToolTip" Value="{Binding ., Converter={StaticResource SerializablePropertyToTypeStringConverter}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Copy name" Command="{Binding CopyPropertyNameCommand}" />
                                        <Separator />
                                        <MenuItem Header="Delete"
                                                  Command="{Binding Source={StaticResource Proxy}, Path=Data.RemovePropertyCommand}"
                                                  CommandParameter="{Binding .}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                                        <Grid Background="{TemplateBinding Background}">
                                            <ContentPresenter Margin="9,4" VerticalAlignment="Center" />
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ResourceDictionary>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Tr Key=CommonName}" Width="Auto" Binding="{Binding PropertyName}" />
                    <DataGridTemplateColumn Header="{loc:Tr Key=CommonValue}" Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding .}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
