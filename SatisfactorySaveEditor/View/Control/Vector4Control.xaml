<UserControl x:Class="SatisfactorySaveEditor.View.Control.Vector4Control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="X" />
                <TextBox x:Name="XBox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Vector.X, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="Y" />
                <TextBox x:Name="YBox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Vector.Y, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </DockPanel>
        </Border>

        <Border Grid.Column="4" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="Z" />
                <TextBox x:Name="ZBox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Vector.Z, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </DockPanel>
        </Border>

        <Border Grid.Column="6" Background="{DynamicResource Brush.ControlFill}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="{StaticResource Radius.Control}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.FG2}" Text="W" />
                <TextBox x:Name="WBox"
                         Background="Transparent" BorderThickness="0" Padding="0,5,6,5"
                         Text="{Binding Vector.W, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
