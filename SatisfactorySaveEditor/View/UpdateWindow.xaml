<Window x:Class="SatisfactorySaveEditor.View.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SatisfactorySaveEditor.Util"
        mc:Ignorable="d"
        x:Name="UpdateWin"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Window}"
        Foreground="{DynamicResource Brush.FG1}"
        FontFamily="{StaticResource Font.UI}"
        TextOptions.TextFormattingMode="Display"
        Title="{loc:Tr Key=MsgUpdate_Title}" Height="560" Width="620">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource Text.Header}" Text="{loc:Tr Key=UpdateWindowHeader}" />
            <TextBlock Style="{StaticResource Text.Caption}" Text="{loc:Tr Key=UpdateWindowSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <TextBlock Text="{Binding Changelog, Mode=OneTime}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.FG1}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="{StaticResource Font.Small}"
                           LineHeight="18" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{loc:Tr Key=ButtonDisableAutoCheck}"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Command="{Binding DisableAutoCheckCommand}"
                    CommandParameter="{Binding ElementName=UpdateWin}" />
            <Button Content="{loc:Tr Key=ButtonRemindLater}"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding ElementName=UpdateWin}" />
            <Button Content="{loc:Tr Key=ButtonOpenReleasePage}"
                    Padding="20,6"
                    Style="{StaticResource Button.Accent}"
                    IsDefault="True"
                    Command="{Binding OpenCommand}"
                    CommandParameter="{Binding ElementName=UpdateWin}" />
        </StackPanel>
    </Grid>
</Window>
