<Window x:Class="SatisfactorySaveEditor.View.World3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        Title="3D ワールドビュー — Satisfactory Save Editor"
        Height="820" Width="1280"
        Background="#0E1116"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <hx:Viewport3DX x:Name="viewport" UseDefaultGestures="False" />

        <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="12" Padding="10,7"
                Background="#B0141A22" CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="infoText" Foreground="#E6EBF0" FontSize="13" />
                <TextBlock Foreground="#8A949C" FontSize="11" Margin="0,4,0,0"
                           Text="WASD=移動 / Q・Z=上下 / 右ドラッグ=回転 / ホイール=ズーム / 左クリック=選択 / Delete=削除 / Ctrl+D=複製" />
            </StackPanel>
        </Border>

        <!-- クリックしたオブジェクトの詳細情報（左下・未選択時は非表示） -->
        <Border x:Name="detailPanel" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Margin="12" Padding="13,11" MaxWidth="440"
                Background="#D2141A22" CornerRadius="10" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="detailTitle" Foreground="#F2F5F8" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock x:Name="detailBody" Foreground="#AEB8C0" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
