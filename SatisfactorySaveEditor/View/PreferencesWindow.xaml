<Window x:Class="SatisfactorySaveEditor.View.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SatisfactorySaveEditor.Util"
        mc:Ignorable="d"
        x:Name="PreferencesWin"
        DataContext="{Binding PreferencesWindowViewModel, Source={StaticResource Locator}, Mode=OneTime}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Window}"
        Foreground="{DynamicResource Brush.FG1}"
        FontFamily="{StaticResource Font.UI}"
        TextOptions.TextFormattingMode="Display"
        Title="{loc:Tr Key=PrefsTitle}" Height="520" Width="520">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource Text.Header}" Text="{loc:Tr Key=PrefsTitle}" />
            <TextBlock Style="{StaticResource Text.Caption}" Text="{loc:Tr Key=PrefsSubtitle}" />
        </StackPanel>

        <!-- 設定カード -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                VerticalAlignment="Top">
            <StackPanel>

                <HeaderedContentControl Header="{loc:Tr Key=PrefsGeneralHeader}">
                    <StackPanel>
                        <CheckBox x:Name="AutoUpdateCheckbox"
                                  Content="{loc:Tr Key=PrefsCheckUpdatesOnLaunch}"
                                  IsChecked="{Binding AutoUpdate}"
                                  Margin="0,2" />
                        <TextBlock Margin="26,-2,0,8"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   Text="{loc:Tr Key=PrefsCheckUpdatesOnLaunchDesc}" />

                        <CheckBox x:Name="AutoBackupCheckbox"
                                  Content="{loc:Tr Key=PrefsBackupBeforeWriting}"
                                  IsChecked="{Binding AutoBackup}"
                                  Margin="0,2" />
                        <TextBlock Margin="26,-2,0,0"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   Text="{loc:Tr Key=PrefsBackupDesc}" />
                    </StackPanel>
                </HeaderedContentControl>

                <HeaderedContentControl Header="{loc:Tr Key=PrefsLanguageHeader}" Margin="0,12,0,0">
                    <StackPanel>
                        <ComboBox x:Name="LanguageComboBox"
                                  ItemsSource="{Binding AvailableCultures}"
                                  SelectedItem="{Binding SelectedCulture}"
                                  DisplayMemberPath="NativeName"
                                  Margin="0,2,0,4" />
                        <TextBlock Margin="2,0,0,0"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   Text="{loc:Tr Key=PrefsLanguageDesc}" />
                    </StackPanel>
                </HeaderedContentControl>

            </StackPanel>
        </Border>

        <!-- フッターボタン -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{loc:Tr Key=ButtonCancel}"
                        Margin="0,0,8,0"
                        Padding="20,6"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding ElementName=PreferencesWin}" />
                <Button Content="{loc:Tr Key=ButtonApply}"
                        Margin="0,0,8,0"
                        Padding="20,6"
                        Command="{Binding ApplyCommand}"
                        IsEnabled="{Binding CanApply}" />
                <Button Content="{loc:Tr Key=ButtonOK}"
                        Padding="20,6"
                        Style="{StaticResource Button.Accent}"
                        Command="{Binding AcceptCommand}"
                        CommandParameter="{Binding ElementName=PreferencesWin}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
