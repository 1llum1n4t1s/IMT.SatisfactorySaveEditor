<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- macOS Tahoe Dark 風のカラーパレット。Lhamiel / RealTimeTranslator と同一の体系で
         Apple System Colors (Dark Mode) をベースに調整している。Light テーマを追加する場合は
         同名キーで Colors.Light.xaml を作り、App.xaml のマージ先を差し替えるだけで動く。 -->

    <!-- ウィンドウ / 主要サーフェス -->
    <Color x:Key="Color.Window">#FF1C1C1E</Color>
    <Color x:Key="Color.Container">#992C2C2E</Color>
    <Color x:Key="Color.ContainerAlt">#993A3A3C</Color>
    <Color x:Key="Color.ContainerSolid">#FF2C2C2E</Color>

    <!-- テキスト -->
    <Color x:Key="Color.FG1">#FFF5F5F7</Color>
    <Color x:Key="Color.FG2">#FF98989D</Color>
    <Color x:Key="Color.FG3">#FF636366</Color>
    <Color x:Key="Color.FGDisabled">#FF48484A</Color>

    <!-- 線 / 仕切り -->
    <Color x:Key="Color.Border">#26FFFFFF</Color>
    <Color x:Key="Color.BorderStrong">#40FFFFFF</Color>
    <Color x:Key="Color.Divider">#1AFFFFFF</Color>

    <!-- アクセント（Apple System Blue / Dark Mode） -->
    <Color x:Key="Color.Accent">#FF0A84FF</Color>
    <Color x:Key="Color.AccentHover">#FF409CFF</Color>
    <Color x:Key="Color.AccentPressed">#FF0870D9</Color>
    <Color x:Key="Color.AccentSubtle">#330A84FF</Color>
    <Color x:Key="Color.OnAccent">#FFFFFFFF</Color>

    <!-- ステータス（macOS システムカラー Dark） -->
    <Color x:Key="Color.Success">#FF30D158</Color>
    <Color x:Key="Color.Warning">#FFFF9F0A</Color>
    <Color x:Key="Color.Danger">#FFFF453A</Color>

    <!-- コントロール塗り -->
    <Color x:Key="Color.ControlFill">#FF3A3A3C</Color>
    <Color x:Key="Color.ControlFillHover">#FF48484A</Color>
    <Color x:Key="Color.ControlFillPressed">#FF2C2C2E</Color>
    <Color x:Key="Color.ControlFillDisabled">#FF1C1C1E</Color>

    <!-- ホバー / 選択（透明レイヤー） -->
    <Color x:Key="Color.HoverOverlay">#12FFFFFF</Color>
    <Color x:Key="Color.SelectedOverlay">#20FFFFFF</Color>

    <!-- タイトルバー -->
    <Color x:Key="Color.TitleBar">#FF1C1C1E</Color>
    <Color x:Key="Color.TitleBarBorder">#1AFFFFFF</Color>

</ResourceDictionary>
