<Window x:Class="SatisfactorySaveEditor.Cheats.MassDismantleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SatisfactorySaveEditor.Cheats"
        xmlns:loc="clr-namespace:SatisfactorySaveEditor.Util"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        ContentRendered="Window_ContentRendered"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Window}"
        Foreground="{DynamicResource Brush.FG1}"
        FontFamily="{StaticResource Font.UI}"
        TextOptions.TextFormattingMode="Display"
        Title="{loc:Tr Key=MassDismantleTitle}"
        SizeToContent="Height"
        Width="460"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource Text.Header}" Text="{loc:Tr Key=MassDismantleTitle}" />
            <TextBlock Style="{StaticResource Text.Caption}" Text="{loc:Tr Key=MassDismantleSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <HeaderedContentControl x:Name="xHeader" Header="{loc:Tr Key=MassDismantleXCoord}">
                    <local:PlaceholderTextBox x:Name="xCoordinate" Placeholder="123456" />
                </HeaderedContentControl>
                <HeaderedContentControl x:Name="yHeader" Header="{loc:Tr Key=MassDismantleYCoord}">
                    <local:PlaceholderTextBox x:Name="yCoordinate" Placeholder="123456" />
                </HeaderedContentControl>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="helpButton"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Click="HelpButton_Click"
                    Content="_Help" />
            <Button Content="_Done"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Click="Done_Click" />
            <Button x:Name="nextButton"
                    Padding="20,6"
                    Style="{StaticResource Button.Accent}"
                    IsDefault="True"
                    Click="Next_Click"
                    Content="{loc:Tr Key=ButtonNextPoint}" />
        </StackPanel>
    </Grid>
</Window>
