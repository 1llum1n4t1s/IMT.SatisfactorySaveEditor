<Window x:Class="SatisfactorySaveEditor.Cheats.UnlockResearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SatisfactorySaveEditor.Cheats"
        xmlns:loc="clr-namespace:SatisfactorySaveEditor.Util"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="UnlockResearchPickWindow"
        DataContext="{Binding UnlockResearchWindowViewModel, Source={StaticResource Locator}, Mode=OneTime}"
        Background="{DynamicResource Brush.Window}"
        Foreground="{DynamicResource Brush.FG1}"
        FontFamily="{StaticResource Font.UI}"
        TextOptions.TextFormattingMode="Display"
        Title="{loc:Tr Key=UnlockResearchTitle}"
        WindowStartupLocation="CenterOwner"
        Width="1400" Height="640" MinWidth="900" MinHeight="500">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource Text.Header}" Text="{loc:Tr Key=UnlockResearchHeader}" />
            <TextBlock Style="{StaticResource Text.Caption}" Text="{loc:Tr Key=UnlockResearchSubtitle}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Available -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{DynamicResource Brush.Divider}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <TextBlock Style="{StaticResource Text.SubHeader}" Text="{loc:Tr Key=UnlockResearchAvailable}" />
                    </Border>
                    <ListBox Name="availableListbox"
                             ItemsSource="{Binding Available}"
                             SelectionMode="Extended"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8" />
                </DockPanel>
            </Border>

            <!-- 中央ボタン列 -->
            <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                <Button x:Name="addButton"
                        Margin="0,4"
                        Padding="12,8"
                        Command="{Binding AddOneCommand}"
                        CommandParameter="{Binding ElementName=availableListbox, Path=SelectedItems}"
                        Content="{loc:Tr Key=UnlockResearchUnlock}" />
                <Button x:Name="removeButton"
                        Margin="0,4"
                        Padding="12,8"
                        Command="{Binding RemoveOneCommand}"
                        CommandParameter="{Binding ElementName=unlockedListbox, Path=SelectedItems}"
                        Content="{loc:Tr Key=UnlockResearchRemove}" />

                <Separator Margin="0,16" />

                <Button x:Name="addAllButton"
                        Margin="0,4"
                        Padding="12,8"
                        Command="{Binding AddAllCommand}"
                        Content="{loc:Tr Key=UnlockResearchUnlockAll}" />
                <Button x:Name="removeAllButton"
                        Margin="0,4"
                        Padding="12,8"
                        Command="{Binding RemoveAllCommand}"
                        Content="{loc:Tr Key=UnlockResearchRemoveAll}" />

                <Separator Margin="0,16" />

                <Button x:Name="addAllAlternativesButton"
                        Margin="0,4"
                        Padding="12,8"
                        Command="{Binding AddAllAlternativesCommand}">
                    <TextBlock Text="{loc:Tr Key=UnlockResearchUnlockAllAlternatives}"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </Button>
            </StackPanel>

            <!-- Unlocked -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{DynamicResource Brush.Divider}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <TextBlock Style="{StaticResource Text.SubHeader}" Text="{loc:Tr Key=UnlockResearchUnlocked}" />
                    </Border>
                    <ListBox Name="unlockedListbox"
                             ItemsSource="{Binding Unlocked}"
                             SelectionMode="Extended"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- フッターボタン -->
        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="cancelButton"
                    Margin="0,0,8,0"
                    Padding="20,6"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding ElementName=UnlockResearchPickWindow}"
                    Content="{loc:Tr Key=ButtonCancelAccel}" />
            <Button x:Name="doneButton"
                    Padding="20,6"
                    Style="{StaticResource Button.Accent}"
                    IsDefault="True"
                    Command="{Binding OkCommand}"
                    CommandParameter="{Binding ElementName=UnlockResearchPickWindow}"
                    Content="{loc:Tr Key=ButtonDone}" />
        </StackPanel>
    </Grid>
</Window>
